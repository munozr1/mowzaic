# ===========================
# MOWZAIC BACKEND ENVIRONMENT VARIABLES
# ===========================
# This is a template file. Setup instructions:
#
# DEVELOPMENT:
#   1. Copy this file to .env.development
#   2. Fill in your development values
#   3. Run with: NODE_ENV=development npm start (or leave NODE_ENV unset)
#
# PRODUCTION:
#   1. Copy this file to .env (production values)
#   2. Fill in your production values
#   3. Run with: NODE_ENV=production npm start
#
# The backend automatically loads:
#   - .env.development when NODE_ENV !== 'production'
#   - .env when NODE_ENV === 'production'
#
# Never commit .env or .env.development to git!

# ===========================
# APPLICATION CONFIGURATION
# ===========================

# Backend server port
PORT=3000

# Application mode: development, production, test
MODE=development

# Node environment: development, production, test
NODE_ENV=development

# ===========================
# SUPABASE (Backend - Admin Access)
# ===========================

# Supabase project URL
SUPABASE_URL=https://your-project.supabase.co

# Supabase anonymous (public) key - respects RLS
SUPABASE_ANON_KEY=sb_publishable_your-anon-key

# Supabase service role key (ADMIN access - bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your-service-role-key

# Supabase JWT secret (for verifying JWT tokens)
# Get from: Supabase Dashboard → Settings → API → JWT Settings → JWT Secret (standby key)
SUPABASE_JWT_SECRET=your-jwt-secret-here

# ===========================
# STRIPE (Backend - Secret Keys)
# ===========================

# Stripe publishable key (pk_test_ for testing, pk_live_ for production)
STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key

# Stripe secret key (sk_test_ for testing, sk_live_ for production)
STRIPE_SECRET_KEY=sk_test_your-secret-key

# Stripe webhook signing secret
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Product ID for first-time booking service
STRIPE_FIRST_TIME_SERVICE_ID=prod_xxx

# Product ID for recurring subscription service
STRIPE_RECURRING_SERVICE_ID=prod_xxx

# ===========================
# AUTHENTICATION & SECURITY
# ===========================

# DEPRECATED: Custom JWT secrets (kept for backward compatibility)
# Frontend now uses Supabase authentication - these are no longer needed
# JWT access token signing secret (generate with: openssl rand -base64 32)
ACCESS_TOKEN_SECRET=your-access-token-secret

# JWT refresh token signing secret (generate with: openssl rand -base64 32)
REFRESH_TOKEN_SECRET=your-refresh-token-secret

# Cookie signing secret
COOKIE_SECRET=your-cookie-secret

# Google OAuth client ID
MOWZAIC_GOOGLE_WEB_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Google OAuth client secret
MOWZAIC_GOOGLE_WEB_CLIENT_SECRET=GOCSPX-your-google-client-secret

# ===========================
# NOTES
# ===========================
#
# 1. AUTHENTICATION:
#    - Frontend uses Supabase Auth (Vercel serverless functions)
#    - Tokens sent in HTTP-only cookie 'sb-access-token'
#    - Backend verifies ES256/HS256 tokens with SUPABASE_JWT_SECRET
#    - Custom JWT routes (/login, /register) are DEPRECATED
#
# 2. OVERLAPPING VARIABLES WITH FRONTEND:
#    - SUPABASE_URL (same)
#    - SUPABASE_ANON_KEY (same)
#    - STRIPE_PUBLISHABLE_KEY (frontend uses VITE_STRIPE_PUBLISHABLE_KEY)
#    - MODE (same concept)
#
# 3. BACKEND-ONLY VARIABLES:
#    - SUPABASE_SERVICE_ROLE_KEY (service role - NEVER expose to frontend)
#    - SUPABASE_JWT_SECRET (for JWT verification - NEVER expose to frontend)
#    - STRIPE_SECRET_KEY (admin access - NEVER expose to frontend)
#    - STRIPE_WEBHOOK_SECRET (for webhook signature verification)
#    - STRIPE_FIRST_TIME_SERVICE_ID (business logic)
#    - STRIPE_RECURRING_SERVICE_ID (business logic)
#    - ACCESS_TOKEN_SECRET (DEPRECATED - kept for backward compatibility)
#    - REFRESH_TOKEN_SECRET (DEPRECATED - kept for backward compatibility)
#    - COOKIE_SECRET (session management)
#    - MOWZAIC_GOOGLE_WEB_CLIENT_SECRET (OAuth server-side)
#    - PORT (server configuration)
#
# 4. SECURITY:
#    - SUPABASE_SERVICE_ROLE_KEY is your service role key - it bypasses ALL RLS policies
#    - SUPABASE_JWT_SECRET verifies JWT tokens - never expose to client
#    - Use service role key only for admin operations and public endpoint queries
#    - Never expose to browser/frontend
#
# 5. STRIPE:
#    - Backend handles all payment processing and webhook events
#    - Frontend only needs publishable key for Stripe.js
#    - Product IDs used for subscription/booking creation logic
#
# 6. ENVIRONMENTS:
#    - Development: Use .env.development (loaded when NODE_ENV !== 'production')
#    - Production: Use .env (loaded when NODE_ENV === 'production')
#    - Testing: Use separate test credentials
#
# 7. HOW TO GET SUPABASE JWT SECRET:
#    - Go to Supabase Dashboard
#    - Settings → API → JWT Settings
#    - Copy "JWT Secret" (standby key recommended)
#
# 8. HOW TO GENERATE SECRETS:
#    - ACCESS_TOKEN_SECRET: openssl rand -base64 32
#    - REFRESH_TOKEN_SECRET: openssl rand -base64 32
#    - COOKIE_SECRET: openssl rand -base64 32
#    - COOKIE_SECRET: openssl rand -base64 32
